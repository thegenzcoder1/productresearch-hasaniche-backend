PORT=5011
JWT_SECRET=<64-char-random-string>
ADMIN_USER=hariharan
ADMIN_PASSWORD=<strong-password>
NODE_ENV=production
# Local testing only: set to true to allow any origin. Leave unset in production.
DISABLE_CORS=false

# ── PERSISTENT STORAGE (PRODUCTION) ───────────────────────────────────────
# Point these to a directory OUTSIDE the repo so deleting / re-cloning the repo
# can NEVER delete your data. Create them once:
#   mkdir -p /home/deploy/pr-persistent/data /home/deploy/pr-persistent/uploads
# Leave unset for local dev (defaults to ./data and ./uploads inside the app).
DATA_DIR=/home/deploy/pr-persistent/data
UPLOAD_DIR=/home/deploy/pr-persistent/uploads
